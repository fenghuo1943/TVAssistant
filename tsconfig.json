{
  "compilerOptions": {
    "target": "ES2020",
    "module": "Nodenext",
    "moduleResolution": "nodenext",
    "rewriteRelativeImportExtensions": true,
    "outDir": "dist",
    "rootDir": ".",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "moduleDetection": "force"
  },
  "include": ["electron/**/*.ts", "src/**/*.ts", "src/**/*.vue"]
}
